# Copy to .env and fill in — .env is gitignored.
# Get the key from wowaudit: Team Settings → API.
WOWAUDIT_API_KEY=your-key-here

# Optional: how far back attendance statistics reach (days).
# ATTENDANCE_DAYS=60

# Optional: set to 1 to skip gear/enchant enrichment from Raider.IO.
# SKIP_RAIDERIO=1
